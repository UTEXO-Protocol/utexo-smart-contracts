# =============================================================================
# Environment for deploy scripts (script/deploy/)
#
# Usage:
#   cp .env.deploy.example .env.deploy
#   # fill in values, then load before running forge:
#   set -a && source .env.deploy && set +a
#   forge script script/deploy/DeployAll.s.sol --rpc-url $RPC_URL --broadcast --verify
# =============================================================================

# -----------------------------------------------------------------------------
# Common (shared with interact .env)
# -----------------------------------------------------------------------------

# Deployer private key (no 0x prefix required; Foundry accepts either form)
PRIVATE_KEY=

# RPC endpoint for the target network
RPC_URL=

# Etherscan-compatible API key for contract verification
# Etherscan:  https://etherscan.io/myapikey
# Basescan:   https://basescan.org/myapikey
# Arbiscan:   https://arbiscan.io/myapikey
ETHERSCAN_API_KEY=

# -----------------------------------------------------------------------------
# Bridge / BaseBridge
# -----------------------------------------------------------------------------

# Accepted ERC-20 for the main Bridge (USDT0)
USDT0_ADDRESS=

# BtcRelay contract address used by Bridge.fundsOut to verify Bitcoin headers.
BTC_RELAY_ADDRESS=

# Initial LayerZero adapter (optional). Leave as 0x0 if the adapter isn't
# deployed yet; federation can wire it later via
# `proposeAdminExecute(Bridge.setLZAdapter(adapter))`. The Bridge accepts
# adapter-only `fundsIn(amount, sourceChainId, ...)` calls *only* from the
# configured adapter.
LZ_ADAPTER=0x0000000000000000000000000000000000000000

# CommissionManager address — only needed for step-by-step deploys (DeployAll
# computes it on the fly).
COMMISSION_MANAGER=

# RouteRegistry address — only needed for step-by-step Bridge redeploys against
# an existing registry. DeployAll predicts and deploys a fresh registry pinned
# to the predicted Bridge address.
ROUTE_REGISTRY_ADDRESS=

# -----------------------------------------------------------------------------
# CommissionManager — Chainlink ETH/USD feed (NATIVE-currency commissions)
# -----------------------------------------------------------------------------

# Chainlink ETH/USD aggregator address. Required only if any commission route
# uses NATIVE currency.
#
# Reference (Chainlink Data Feeds, https://data.chain.link):
#   Arbitrum One  ETH/USD  0x639Fe6ab55C921f74e7fac1ee960C0B6293ba612
#   Ethereum L1   ETH/USD  0x5f4eC3Df9cbd43714FE2740f5E3616155c5b8419
ETH_USD_FEED=

# Maximum staleness (seconds) before the feed answer is rejected.
# Use the feed's published heartbeat from the Chainlink dashboard plus a
# small buffer for network/timestamp jitter (e.g. Arbitrum ETH/USD is 86400 s,
# 87000 leaves ~10 min slack).
ETH_USD_HEARTBEAT=87000

# -----------------------------------------------------------------------------
# MultisigProxy
# -----------------------------------------------------------------------------

# Existing Bridge deployment to own — only needed for step-by-step
# (when DeployMultisigProxy runs after DeployBridge but without DeployAll).
BRIDGE_ADDRESS=

# Comma-separated address lists — order matters, matches bitmap bit index.
ENCLAVE_SIGNERS=
FEDERATION_SIGNERS=

# M-of-N thresholds.
ENCLAVE_THRESHOLD=2
FEDERATION_THRESHOLD=2

# Where withdrawTokenCommission() / withdrawNativeCommission() send funds.
COMMISSION_RECIPIENT=

# Timelock between propose and execute for federation proposals (seconds).
TIMELOCK_DURATION=3600
