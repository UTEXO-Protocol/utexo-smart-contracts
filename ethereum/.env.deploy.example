# =============================================================================
# Environment for deploy scripts (script/deploy/)
#
# Usage:
#   cp .env.deploy.example .env.deploy
#   # fill in values, then load before running forge:
#   set -a && source .env.deploy && set +a
#   forge script script/deploy/DeployAll.s.sol --rpc-url $RPC_URL --broadcast --verify
# =============================================================================

# -----------------------------------------------------------------------------
# Common (shared with interact .env)
# -----------------------------------------------------------------------------

# Deployer private key (no 0x prefix required; Foundry accepts either form)
PRIVATE_KEY=

# RPC endpoint for the target network
RPC_URL=

# Etherscan-compatible API key for contract verification
# Etherscan:  https://etherscan.io/myapikey
# Basescan:   https://basescan.org/myapikey
# Arbiscan:   https://arbiscan.io/myapikey
ETHERSCAN_API_KEY=

# -----------------------------------------------------------------------------
# Bridge / BaseBridge
# -----------------------------------------------------------------------------

# Accepted ERC-20 for the main Bridge (USDT0)
USDT0_ADDRESS=

# BtcRelay contract address used by Bridge.fundsOut to verify Bitcoin headers.
BTC_RELAY_ADDRESS=

# This bridge's chain identifier as used in CommissionManager route keys.
SOURCE_CHAIN_NAME=arbitrum

# CommissionManager address — only needed for step-by-step deploys (DeployAll
# computes it on the fly).
COMMISSION_MANAGER=

# -----------------------------------------------------------------------------
# MultisigProxy
# -----------------------------------------------------------------------------

# Existing Bridge deployment to own — only needed for step-by-step
# (when DeployMultisigProxy runs after DeployBridge but without DeployAll).
BRIDGE_ADDRESS=

# Comma-separated address lists — order matters, matches bitmap bit index.
ENCLAVE_SIGNERS=
FEDERATION_SIGNERS=

# M-of-N thresholds.
ENCLAVE_THRESHOLD=2
FEDERATION_THRESHOLD=2

# Where withdrawTokenCommission() / withdrawNativeCommission() send funds.
COMMISSION_RECIPIENT=

# Timelock between propose and execute for federation proposals (seconds).
TIMELOCK_DURATION=3600
