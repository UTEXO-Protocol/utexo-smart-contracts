# Private key of the deployer account
PRIVATE_KEY=

# RPC endpoint for the target network
RPC_URL=

# Etherscan-compatible API key for contract verification
# Etherscan:  https://etherscan.io/myapikey
# Basescan:   https://basescan.org/myapikey
# Arbiscan:   https://arbiscan.io/myapikey
ETHERSCAN_API_KEY=

# Comma-separated list of ERC-20 token addresses to support on the bridge
# Example: 0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48,0xdAC17F958D2ee523a2206206994597C13D831ec7
SUPPORTED_TOKENS=
