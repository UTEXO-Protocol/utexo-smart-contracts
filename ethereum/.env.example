# =============================================================================
# Deploy — shared
# =============================================================================

# Deployer private key (no 0x prefix required; Foundry accepts either form)
PRIVATE_KEY=

# RPC endpoint for the target network
RPC_URL=

# Etherscan-compatible API key for contract verification
# Etherscan:  https://etherscan.io/myapikey
# Basescan:   https://basescan.org/myapikey
# Arbiscan:   https://arbiscan.io/myapikey
ETHERSCAN_API_KEY=

# =============================================================================
# Deploy — Bridge / BaseBridge
# =============================================================================

# Accepted ERC-20 for the main Bridge (USDT0)
USDT0_ADDRESS=

# =============================================================================
# Deploy — MultisigProxy
# =============================================================================

# Existing Bridge deployment to own (leave empty when using DeployAll.s.sol)
BRIDGE_ADDRESS=

# Comma-separated lists — order matters, matches bitmap bit index
ENCLAVE_SIGNERS=
FEDERATION_SIGNERS=

# M-of-N thresholds
ENCLAVE_THRESHOLD=2
FEDERATION_THRESHOLD=2

# Where withdrawCommission() / withdrawNativeCommission() send funds
COMMISSION_RECIPIENT=

# Timelock between propose and execute for federation proposals (seconds)
TIMELOCK_DURATION=3600

# =============================================================================
# Interact — Bridge / BaseBridge calls
# =============================================================================

# AMOUNT is in token base units (wei for 18-decimal tokens)
AMOUNT=
OPERATION_ID=
TX_ID=
DESTINATION_CHAIN=rgb
DESTINATION_ADDRESS=
SOURCE_CHAIN=rgb
SOURCE_ADDRESS=
RECIPIENT=
OP_NONCE=0

# Deployed BaseBridge address for BaseBridge* interact scripts
BASE_BRIDGE_ADDRESS=

# =============================================================================
# Interact — MultisigProxy calls
# =============================================================================

# Deployed MultisigProxy address
PROXY_ADDRESS=

# Comma-separated private keys (hex) — ordered by signer bit index
ENCLAVE_PKS=
FED_PKS=

# Bitmap of participating signers (e.g. 0x3 for signers 0 and 1)
ENCLAVE_BITMAP=0x3
FED_BITMAP=0x3

# How far ahead to set the deadline (seconds)
DEADLINE_OFFSET=3600
