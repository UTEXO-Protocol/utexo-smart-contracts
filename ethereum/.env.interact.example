# =============================================================================
# Environment for interaction scripts (script/interact/)
#
# Usage:
#   cp .env.interact.example .env.interact
#   # fill in values for the call you want to make, then load before running:
#   set -a && source .env.interact && set +a
#   forge script script/interact/BridgeFundsIn.s.sol --rpc-url $RPC_URL --broadcast
# =============================================================================

# -----------------------------------------------------------------------------
# Common (shared with deploy .env)
# -----------------------------------------------------------------------------

# Caller private key (the EOA that submits the tx; for fundsIn this is the user,
# for MultisigExecuteFundsOut this is just the relayer — TEE keys live below).
PRIVATE_KEY=

# RPC endpoint for the target network
RPC_URL=

# -----------------------------------------------------------------------------
# Deployed contract addresses
# -----------------------------------------------------------------------------

BRIDGE_ADDRESS=
PROXY_ADDRESS=
BASE_BRIDGE_ADDRESS=

# -----------------------------------------------------------------------------
# fundsIn parameters (BridgeFundsIn.s.sol / BaseBridgeFundsIn.s.sol)
# -----------------------------------------------------------------------------

# Token base units (wei for 18-decimal tokens; for 6-decimal USDT0 → 1 USDT = 1_000_000)
AMOUNT=

# Backend-assigned operation identifier (replay-protected on Bridge.fundsIn /
# referenced on Bridge.fundsOut as the recorded fundsIn id).
OPERATION_ID=

DESTINATION_CHAIN=rgb
DESTINATION_ADDRESS=

# -----------------------------------------------------------------------------
# fundsOut parameters (MultisigExecuteFundsOut.s.sol / BaseBridgeFundsOut.s.sol)
# -----------------------------------------------------------------------------

RECIPIENT=
SOURCE_CHAIN=rgb
DEST_CHAIN=arbitrum
SOURCE_ADDRESS=

# Bitcoin-side burn replay guard + BtcRelay verification
BURN_ID=
BLOCK_HEIGHT=
COMMITMENT_HASH=

# Comma-separated list of fundsIn operationIds the fundsOut consumes (e.g. 42,43)
FUNDS_IN_IDS=

# -----------------------------------------------------------------------------
# Multisig signing (TEE / Federation simulation for testnet)
# -----------------------------------------------------------------------------

# Comma-separated private keys (hex) — ordered by signer bit index.
# In production, TEE enclaves produce these signatures; this is for local sims.
ENCLAVE_PKS=
FED_PKS=

# Bitmap of participating signers (e.g. 0x3 for signers 0 and 1).
ENCLAVE_BITMAP=0x3
FED_BITMAP=0x3

# How far ahead (seconds) to set the signed deadline.
DEADLINE_OFFSET=3600
